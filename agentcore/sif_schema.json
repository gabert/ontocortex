{
  "type": "object",
  "properties": {
    "operations": {
      "type": "array",
      "description": "List of SIF operations to execute in order.",
      "items": {
        "type": "object",
        "properties": {
          "op": {
            "type": "string",
            "enum": ["query", "create", "update", "delete", "action"],
            "description": "Operation type. Use 'action' for domain-specific business logic."
          },
          "entity": {
            "type": "string",
            "description": "Ontology class name (e.g. Customer, Policy, Pet). Not required for action ops."
          },
          "action": {
            "type": "string",
            "description": "Action only: name of the registered domain action to invoke."
          },
          "params": {
            "type": "object",
            "description": "Action only: parameters to pass to the action."
          },
          "fields": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Query only: which fields to return. Omit for all fields."
          },
          "filters": {
            "type": "object",
            "description": "Equality filters: {property_name: value}."
          },
          "relations": {
            "type": "array",
            "description": "Query only: chain of relations to traverse for joins.",
            "items": {
              "type": "object",
              "properties": {
                "rel": {
                  "type": "string",
                  "description": "Ontology relationship name."
                },
                "entity": {
                  "type": "string",
                  "description": "Ontology class on the other end."
                },
                "filters": {
                  "type": "object",
                  "description": "Equality filters on the related entity."
                }
              },
              "required": ["rel", "entity"]
            }
          },
          "data": {
            "type": "object",
            "description": "Create/update: {property_name: value} to set."
          },
          "resolve": {
            "type": "object",
            "description": "Create only: resolve related entities for FK values. Keys are relationship names, values are {entity, filters} lookup specs."
          },
          "aggregate": {
            "type": "object",
            "description": "Query only: {fn: count|sum|avg|min|max, field?: property_name}.",
            "properties": {
              "fn": {
                "type": "string",
                "enum": ["count", "sum", "avg", "min", "max"]
              },
              "field": {"type": "string"}
            },
            "required": ["fn"]
          },
          "sort": {
            "type": "object",
            "description": "Query only: {field: property_name, dir: asc|desc}.",
            "properties": {
              "field": {"type": "string"},
              "dir": {
                "type": "string",
                "enum": ["asc", "desc"]
              }
            },
            "required": ["field"]
          },
          "limit": {
            "type": "integer",
            "description": "Query only: max rows to return."
          }
        },
        "required": ["op"]
      }
    }
  },
  "required": ["operations"]
}
